# ===========================================
# EduMatrix-AMS Production Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=YourStrongPassword123!
POSTGRES_DB=school_system

# ===========================================
# FLASK APPLICATION
# ===========================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-min-32-chars

# ===========================================
# DOCKER IMAGE (for GitHub Actions deployment)
# ===========================================
GHCR_IMAGE_REPO=your-github-username/edumatrix-ams-pgsql
IMAGE_TAG=latest

# ===========================================
# CLOUDFLARE TUNNEL (Zero-Cost Hosting)
# ===========================================
# Get this from Cloudflare Zero Trust Dashboard:
# Networks > Tunnels > Create Tunnel > Docker > Copy Token
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiYWJjZGVmZzEyMzQ1Njc4OTAiLCJ0IjoiYWJjZGVmZy0xMjM0LTU2NzgtOTBhYi1jZGVmZzEyMzQ1NiIsInMiOiJhYmNkZWZnMTIzNDU2Nzg5MGFiY2RlZmcxMjM0NTY3ODkwYWJjZGVmZzEyMzQ1Njc4OTBhYmNkZWZnMTIzNDU2Nzg5MGFiY2RlZmcxMjM0NTY3ODkwYWJjZGVmZzEyMzQ1Njc4OTBhYmNkZWZnMTIzNDU2Nzg5MCI=

# ===========================================
# OPTIONAL: Firebase (Push Notifications)
# ===========================================
# FIREBASE_CREDENTIALS_FILE=/app/secrets/firebase-adminsdk.json
# Or use JSON string directly:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
